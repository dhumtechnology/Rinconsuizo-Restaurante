# Puerto de la aplicación web (Apache + PHP)
APP_PORT=8080

# Puerto de MySQL expuesto al host (opcional)
DB_PORT=3306

# Puerto de phpMyAdmin
PHPMYADMIN_PORT=8081

# Credenciales MariaDB
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=rinconsuizo
MYSQL_USER=rinconsuizo
MYSQL_PASSWORD=rinconsuizo_secret

# Base de datos del módulo ecommerce/facturación (por defecto usa la misma)
MYSQL_DATABASE_ECOMMERCE=rinconsuizo

# Correo SMTP (verificación de cuenta, pedidos, etc.)
# Gmail: use contraseña de aplicación (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=contraseña_de_aplicacion
SMTP_FROM_EMAIL=tu_correo@gmail.com
SMTP_FROM_NAME=Rincon Suizo
